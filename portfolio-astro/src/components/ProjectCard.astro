---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const cardClass = project.featured ? 'project-card featured reveal' : 'project-card reveal';
---

<article class={cardClass}>
  <div class="project-header">
    <div class="project-icon"><i class={project.icon}></i></div>
    {project.featured && (
      <span class="project-badge" data-i18n="projects.featured">em destaque</span>
    )}
  </div>
  <h3 class="project-title">{project.title}</h3>
  <p class="project-desc" data-i18n={`projects.descriptions.${project.slug}`}>
    {project.description}
  </p>
  <div class="project-tags">
    {project.tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
  <a href={project.githubUrl} target="_blank" rel="noopener" class="project-link">
    <i class="fab fa-github"></i>
    <span data-i18n="projects.viewCode">Ver no GitHub</span>
    <i class="fas fa-arrow-right"></i>
  </a>
</article>
