---
---

<section class="hero" id="hero">
  <div class="container">
    <span class="hero-status" data-i18n="hero.status">Disponível para novos projetos</span>
    <p class="hero-name mono">
      <span class="arrow">&gt;</span>
      <span data-i18n="hero.greeting">Olá, eu sou Natália Barros</span>
    </p>
    <h1 class="hero-title">
      <span data-i18n="hero.title">Desenvolvedora</span><br />
      <span class="accent" data-i18n="hero.titleAccent">Full Stack</span>
    </h1>
    <p class="hero-subtitle" data-i18n-html="hero.subtitle">
      Construo aplicações web modernas com
      <span class="hl">Python, TypeScript e Go</span>
       — do back ao front, do MVP à escala.
    </p>
    <div class="hero-actions">
      <a href="#projetos" class="btn btn-primary">
        <span data-i18n="hero.ctaProjects">Ver Projetos</span>
        <i class="fas fa-arrow-right"></i>
      </a>
      <a href="#contato" class="btn btn-ghost">
        <i class="fas fa-paper-plane"></i>
        <span data-i18n="hero.ctaContact">Conversar</span>
      </a>
    </div>
    <div class="hero-techstrip">
      <span class="label">stack:</span>
      <span class="tech">Python</span><span class="sep">/</span>
      <span class="tech">Django</span><span class="sep">/</span>
      <span class="tech">FastAPI</span><span class="sep">/</span>
      <span class="tech">Next.js</span><span class="sep">/</span>
      <span class="tech">TypeScript</span><span class="sep">/</span>
      <span class="tech">React</span><span class="sep">/</span>
      <span class="tech">Go</span><span class="sep">/</span>
      <span class="tech">Node.js</span>
    </div>
    <div class="hero-social">
      <a
        href="https://github.com/nataliabarros1994?tab=repositories"
        target="_blank"
        rel="noopener"
        class="social-link"
        title="GitHub"
      >
        <i class="fab fa-github"></i>
      </a>
      <a
        href="https://www.linkedin.com/in/nataliachagas1994/"
        target="_blank"
        rel="noopener"
        class="social-link"
        title="LinkedIn"
      >
        <i class="fab fa-linkedin-in"></i>
      </a>
      <a
        href="https://wa.me/5522981507669"
        target="_blank"
        rel="noopener"
        class="social-link"
        title="WhatsApp"
      >
        <i class="fab fa-whatsapp"></i>
      </a>
      <a
        href="https://mail.google.com/mail/?view=cm&to=natalia.goldenglowitsolutions@gmail.com"
        target="_blank"
        rel="noopener"
        class="social-link"
        title="Email"
      >
        <i class="fas fa-envelope"></i>
      </a>
    </div>
  </div>
</section>
